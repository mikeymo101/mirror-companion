# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# Dashboard PIN (for parent dashboard access)
DASHBOARD_PIN=1234

# Child's name
CHILD_NAME=

# Wake word settings
# Custom model path (leave empty to use built-in "hey jarvis" as placeholder)
WAKE_WORD_MODEL_PATH=
# Sensitivity threshold (0.0 to 1.0, higher = fewer false triggers)
WAKE_WORD_THRESHOLD=0.5

# Weather location (latitude/longitude for Open-Meteo, free, no key needed)
# Find yours at: https://www.latlong.net/
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060

# Audio device indices (-1 for system default)
AUDIO_INPUT_DEVICE_INDEX=-1
AUDIO_OUTPUT_DEVICE_INDEX=-1
