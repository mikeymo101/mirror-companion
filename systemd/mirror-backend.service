[Unit]
Description=Mirror Companion Backend
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/mirror-companion/backend
Environment=PATH=/home/pi/mirror-companion/backend/venv/bin:/usr/bin:/bin
ExecStart=/home/pi/mirror-companion/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
