[Unit]
Description=Mirror Companion Frontend (Kiosk)
After=graphical.target mirror-backend.service
Wants=mirror-backend.service

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
ExecStartPre=/bin/sleep 5
ExecStart=/usr/bin/chromium-browser --kiosk --noerrdialogs --disable-infobars --disable-session-crashed-bubble --incognito http://localhost:5173
Restart=always
RestartSec=10

[Install]
WantedBy=graphical.target
